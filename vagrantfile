# -*- mode: ruby -*-
# =============================================================================
# GRC Hyper-V Lab – Vagrantfile
# =============================================================================
#
# NETWORKING DESIGN
# ─────────────────
# Problem: Hyper-V internal switches have no DHCP. Vagrant can't connect
# to a VM that has no IP address.
#
# Solution: Two NICs per VM, two phases per provisioning run.
#
# Phase 1 – Bootstrap (Vagrant connects via Default Switch / DHCP):
#   Vagrant uses NIC1 (Default Switch, always has NAT+DHCP) to connect.
#   A shell provisioner runs inside the VM and sets a static IP on NIC2
#   (GRC-Lab-Switch). WinRM is opened on all adapters.
#
# Phase 2 – Isolate (entirely host-side, no Vagrant reconnect involved):
#   A host-side shell provisioner uses Hyper-V PowerShell to:
#     1. Stop-VM (graceful shutdown)
#     2. Remove-VMNetworkAdapter (removes Default Switch NIC)
#     3. Start-VM (boots with only GRC-Lab-Switch NIC)
#   Vagrant does NOT try to reconnect after a host-side shell provisioner,
#   so no "guest not ready" error occurs.
#
# After Phase 2:
#   All VMs are on static 10.10.10.x addresses only.
#   Ansible on AUDIT-BOX talks to all VMs over those IPs.
#   Vagrant uses winrm.host / ssh.host (set to static IP) for any
#   subsequent provisioners that need to connect.
#
# Prerequisites on Windows host:
#   - Hyper-V enabled (Default Switch is always present)
#   - GRC-Lab-Switch created: .\scripts\setup\create-hyperv-switch.ps1
#   - Vagrant >= 2.4
#   - vagrant plugin install vagrant-reload  (still needed for AUDIT-BOX)
#   - Git
# =============================================================================

DOMAIN      = "corp.grclab.local"
NETBIOS     = "GRCLAB"
LAB_SWITCH  = "GRC-Lab-Switch"
MGMT_SWITCH = "Default Switch"
PREFIX_LEN  = 24

MACHINES = [
  { name: "DC-PRIMARY",          box: "gusztavvargadr/windows-server-2022-standard", ip: "10.10.10.10", ram: 4096, cpus: 2 },
  { name: "DC-SECONDARY",        box: "gusztavvargadr/windows-server-2022-standard", ip: "10.10.10.11", ram: 4096, cpus: 2 },
  { name: "MEMBER-SERVER-01",    box: "gusztavvargadr/windows-server-2019-standard", ip: "10.10.10.20", ram: 4096, cpus: 2 },
  { name: "MEMBER-SERVER-02",    box: "gusztavvargadr/windows-server-2019-standard", ip: "10.10.10.21", ram: 4096, cpus: 2 },
  { name: "WORKSTATION-WIN10-01",box: "gusztavvargadr/windows-10-enterprise",        ip: "10.10.10.31", ram: 4096, cpus: 2 },
  { name: "WORKSTATION-WIN10-02",box: "gusztavvargadr/windows-10-enterprise",        ip: "10.10.10.32", ram: 4096, cpus: 2 },
  { name: "WORKSTATION-WIN11",   box: "gusztavvargadr/windows-11-22h2-enterprise",        ip: "10.10.10.33", ram: 4096, cpus: 2 },
  { name: "AUDIT-BOX",           box: "kalilinux/rolling",                           ip: "10.10.10.50", ram: 4096, cpus: 2 },
].freeze

# =============================================================================
# Phase 1: runs INSIDE the VM via WinRM over Default Switch DHCP address.
# Identifies NIC2 (GRC-Lab-Switch, no IP / APIPA) and sets static lab IP.
# =============================================================================
def win_phase1(static_ip, prefix)
  s = ""
  s << "Write-Host ''\n"
  s << "Write-Host '=== [Phase 1] Setting lab IP " + static_ip + " ===' -ForegroundColor Cyan\n"
  s << "\n"
  s << "# Wait for both NICs to enumerate then find the one with no IP or APIPA\n"
  s << "$labNic = $null\n"
  s << "$tries  = 0\n"
  s << "while (-not $labNic -and $tries -lt 20) {\n"
  s << "  Start-Sleep -Seconds 3\n"
  s << "  $tries++\n"
  s << "  foreach ($a in (Get-NetAdapter | Where-Object Status -eq 'Up')) {\n"
  s << "    $ips = (Get-NetIPAddress -InterfaceIndex $a.ifIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue).IPAddress\n"
  s << "    if (-not $ips -or ($ips | Where-Object { $_ -like '169.254.*' })) {\n"
  s << "      $labNic = $a\n"
  s << "      break\n"
  s << "    }\n"
  s << "  }\n"
  s << "}\n"
  s << "if (-not $labNic) {\n"
  s << "  $labNic = Get-NetAdapter | Where-Object Status -eq 'Up' | Sort-Object ifIndex -Descending | Select-Object -First 1\n"
  s << "  Write-Warning '  Fallback: using adapter ' + $labNic.Name\n"
  s << "}\n"
  s << "Write-Host '  Lab NIC: ' + $labNic.Name\n"
  s << "\n"
  s << "# Clear existing config and set static IP (no gateway -- stays on NIC1 until removed)\n"
  s << "Get-NetIPAddress -InterfaceIndex $labNic.ifIndex -AddressFamily IPv4 -ErrorAction SilentlyContinue | Remove-NetIPAddress -Confirm:$false -ErrorAction SilentlyContinue\n"
  s << "Get-NetRoute     -InterfaceIndex $labNic.ifIndex -ErrorAction SilentlyContinue | Remove-NetRoute -Confirm:$false -ErrorAction SilentlyContinue\n"
  s << "New-NetIPAddress -InterfaceIndex $labNic.ifIndex -IPAddress '" + static_ip + "' -PrefixLength " + prefix.to_s + " -ErrorAction Stop | Out-Null\n"
  s << "Set-DnsClientServerAddress -InterfaceIndex $labNic.ifIndex -ServerAddresses @('10.10.10.10','10.10.10.11') | Out-Null\n"
  s << "Write-Host '  IP set: " + static_ip + "/" + prefix.to_s + "'\n"
  s << "\n"
  s << "# Open WinRM\n"
  s << "Set-ExecutionPolicy Unrestricted -Scope LocalMachine -Force\n"
  s << "winrm quickconfig -q 2>&1 | Out-Null\n"
  s << "winrm set winrm/config              '@{MaxTimeoutms=\"300000\"}'      2>&1 | Out-Null\n"
  s << "winrm set winrm/config/service      '@{AllowUnencrypted=\"true\"}'    2>&1 | Out-Null\n"
  s << "winrm set winrm/config/service/auth '@{Basic=\"true\"}'               2>&1 | Out-Null\n"
  s << "winrm set winrm/config/service/auth '@{Negotiate=\"true\"}'           2>&1 | Out-Null\n"
  s << "winrm set winrm/config/winrs        '@{MaxMemoryPerShellMB=\"1024\"}' 2>&1 | Out-Null\n"
  s << "Get-NetFirewallRule -Name 'WinRM-HTTP-GRC' -ErrorAction SilentlyContinue | Remove-NetFirewallRule\n"
  s << "New-NetFirewallRule -Name 'WinRM-HTTP-GRC' -DisplayName 'WinRM HTTP (GRC Lab)' -Protocol TCP -LocalPort 5985 -Action Allow -Direction Inbound -Profile Any | Out-Null\n"
  s << "Enable-NetFirewallRule -DisplayName 'File and Printer Sharing (Echo Request - ICMPv4-In)' -ErrorAction SilentlyContinue\n"
  s << "Set-ItemProperty -Path 'HKLM:\\System\\CurrentControlSet\\Control\\Terminal Server' -Name fDenyTSConnections -Value 0\n"
  s << "Enable-NetFirewallRule -DisplayGroup 'Remote Desktop' -ErrorAction SilentlyContinue\n"
  s << "\n"
  s << "Write-Host '=== [Phase 1] Complete ===' -ForegroundColor Cyan\n"
  s
end

# =============================================================================
# Phase 2: runs on the WINDOWS HOST (privileged: false = host PowerShell).
# Gracefully stops the VM, removes the Default Switch NIC, restarts the VM.
# Vagrant does NOT try to reconnect after this -- no "guest not ready" error.
# The VM comes back with only the GRC-Lab-Switch NIC (static lab IP).
# =============================================================================
def host_isolate(vm_name, static_ip, mgmt_switch)
  s = ""
  s << "Write-Host ''\n"
  s << "Write-Host '=== [Phase 2] Isolating " + vm_name + " to lab network ===' -ForegroundColor Cyan\n"
  s << "\n"
  s << "# Graceful shutdown\n"
  s << "Write-Host '  Stopping " + vm_name + "...'\n"
  s << "$vm = Get-VM -Name '" + vm_name + "' -ErrorAction Stop\n"
  s << "if ($vm.State -ne 'Off') {\n"
  s << "  Stop-VM -Name '" + vm_name + "' -Force\n"
  s << "  $timeout = 60\n"
  s << "  while ((Get-VM -Name '" + vm_name + "').State -ne 'Off' -and $timeout -gt 0) {\n"
  s << "    Start-Sleep -Seconds 2\n"
  s << "    $timeout -= 2\n"
  s << "  }\n"
  s << "  if ((Get-VM -Name '" + vm_name + "').State -ne 'Off') {\n"
  s << "    Write-Warning '  VM did not stop in time -- forcing off'\n"
  s << "    Stop-VM -Name '" + vm_name + "' -TurnOff\n"
  s << "    Start-Sleep -Seconds 5\n"
  s << "  }\n"
  s << "}\n"
  s << "Write-Host '  VM stopped.'\n"
  s << "\n"
  s << "# Remove the Default Switch NIC\n"
  s << "$mgmtNic = Get-VMNetworkAdapter -VMName '" + vm_name + "' | Where-Object { $_.SwitchName -eq '" + mgmt_switch + "' }\n"
  s << "if ($mgmtNic) {\n"
  s << "  Write-Host '  Removing NIC: ' + $mgmtNic.Name + ' -> ' + $mgmtNic.SwitchName\n"
  s << "  Remove-VMNetworkAdapter -VMName '" + vm_name + "' -VMNetworkAdapterName $mgmtNic.Name\n"
  s << "  Write-Host '  Default Switch NIC removed.' -ForegroundColor Green\n"
  s << "} else {\n"
  s << "  Write-Host '  No Default Switch NIC found (already removed).' -ForegroundColor Yellow\n"
  s << "}\n"
  s << "\n"
  s << "# Start the VM on lab network only\n"
  s << "Write-Host '  Starting " + vm_name + " (lab network only)...'\n"
  s << "Start-VM -Name '" + vm_name + "'\n"
  s << "\n"
  s << "# Wait for VM to start and verify lab IP is reachable\n"
  s << "Write-Host '  Waiting for lab IP " + static_ip + ":5985...'\n"
  s << "$ready = $false\n"
  s << "$wait  = 0\n"
  s << "while (-not $ready -and $wait -lt 120) {\n"
  s << "  Start-Sleep -Seconds 5\n"
  s << "  $wait += 5\n"
  s << "  $test = Test-NetConnection -ComputerName '" + static_ip + "' -Port 5985 -WarningAction SilentlyContinue -ErrorAction SilentlyContinue\n"
  s << "  if ($test.TcpTestSucceeded) { $ready = $true }\n"
  s << "}\n"
  s << "if ($ready) {\n"
  s << "  Write-Host '  " + vm_name + " is up on " + static_ip + " (WinRM reachable)' -ForegroundColor Green\n"
  s << "} else {\n"
  s << "  Write-Warning '  " + vm_name + " WinRM not yet reachable on " + static_ip + " -- Ansible will retry'\n"
  s << "}\n"
  s << "Write-Host '=== [Phase 2] Complete ===' -ForegroundColor Cyan\n"
  s
end

# =============================================================================
# Phase 1 Linux (AUDIT-BOX): sets static IP on NIC2 via nmcli.
# =============================================================================
def linux_phase1(static_ip, prefix)
  s = ""
  s << "#!/usr/bin/env bash\n"
  s << "set -euo pipefail\n"
  s << "echo ''\n"
  s << "echo '=== [Phase 1] Setting lab IP " + static_ip + " ==='\n"
  s << "\n"
  s << "# Find NIC2 -- no IP or APIPA\n"
  s << "LAB_NIC=''\n"
  s << "for iface in $(ls /sys/class/net | grep -v lo | sort); do\n"
  s << "  addr=$(ip -4 addr show \"$iface\" 2>/dev/null | awk '/inet /{print $2}' | head -1)\n"
  s << "  if [ -z \"$addr\" ] || echo \"$addr\" | grep -q '^169\\.254\\.'; then\n"
  s << "    LAB_NIC=\"$iface\"\n"
  s << "    break\n"
  s << "  fi\n"
  s << "done\n"
  s << "[ -z \"$LAB_NIC\" ] && LAB_NIC=$(ls /sys/class/net | grep -v lo | sort | tail -1)\n"
  s << "echo \"  Lab NIC: $LAB_NIC\"\n"
  s << "\n"
  s << "if command -v nmcli &>/dev/null; then\n"
  s << "  nmcli connection delete 'grc-lab-static' 2>/dev/null || true\n"
  s << "  nmcli connection add type ethernet ifname \"$LAB_NIC\" con-name 'grc-lab-static' \\\n"
  s << "    ipv4.method manual \\\n"
  s << "    ipv4.addresses '" + static_ip + "/" + prefix.to_s + "' \\\n"
  s << "    ipv4.dns '10.10.10.10,10.10.10.11' \\\n"
  s << "    ipv6.method disabled\n"
  s << "  nmcli connection up 'grc-lab-static'\n"
  s << "else\n"
  s << "  ip addr flush dev \"$LAB_NIC\" 2>/dev/null || true\n"
  s << "  ip addr add '" + static_ip + "/" + prefix.to_s + "' dev \"$LAB_NIC\"\n"
  s << "  ip link set \"$LAB_NIC\" up\n"
  s << "fi\n"
  s << "\n"
  s << "grep -q '10.10.10.10' /etc/resolv.conf || echo 'nameserver 10.10.10.10' >> /etc/resolv.conf\n"
  s << "grep -q '10.10.10.11' /etc/resolv.conf || echo 'nameserver 10.10.10.11' >> /etc/resolv.conf\n"
  s << "echo '  Done: " + static_ip + "/" + prefix.to_s + "'\n"
  s << "echo '=== [Phase 1] Complete ==='\n"
  s
end

# =============================================================================
# Phase 2 Linux (AUDIT-BOX): host-side stop/remove NIC/start -- same as Windows.
# After restart Vagrant reconnects using ssh.host = static lab IP.
# =============================================================================
def host_isolate_linux(vm_name, static_ip, mgmt_switch)
  s = ""
  s << "Write-Host ''\n"
  s << "Write-Host '=== [Phase 2] Isolating " + vm_name + " to lab network ===' -ForegroundColor Cyan\n"
  s << "$vm = Get-VM -Name '" + vm_name + "' -ErrorAction Stop\n"
  s << "if ($vm.State -ne 'Off') {\n"
  s << "  Stop-VM -Name '" + vm_name + "' -Force\n"
  s << "  $t = 60\n"
  s << "  while ((Get-VM -Name '" + vm_name + "').State -ne 'Off' -and $t -gt 0) { Start-Sleep 2; $t -= 2 }\n"
  s << "}\n"
  s << "$mgmtNic = Get-VMNetworkAdapter -VMName '" + vm_name + "' | Where-Object { $_.SwitchName -eq '" + mgmt_switch + "' }\n"
  s << "if ($mgmtNic) {\n"
  s << "  Remove-VMNetworkAdapter -VMName '" + vm_name + "' -VMNetworkAdapterName $mgmtNic.Name\n"
  s << "  Write-Host '  Default Switch NIC removed.' -ForegroundColor Green\n"
  s << "} else {\n"
  s << "  Write-Host '  No Default Switch NIC found (already removed).' -ForegroundColor Yellow\n"
  s << "}\n"
  s << "Start-VM -Name '" + vm_name + "'\n"
  s << "Write-Host '  Waiting for SSH on " + static_ip + ":22...'\n"
  s << "$ready = $false; $wait = 0\n"
  s << "while (-not $ready -and $wait -lt 180) {\n"
  s << "  Start-Sleep 5; $wait += 5\n"
  s << "  $test = Test-NetConnection -ComputerName '" + static_ip + "' -Port 22 -WarningAction SilentlyContinue -ErrorAction SilentlyContinue\n"
  s << "  if ($test.TcpTestSucceeded) { $ready = $true }\n"
  s << "}\n"
  s << "if ($ready) { Write-Host '  " + vm_name + " SSH reachable on " + static_ip + "' -ForegroundColor Green }\n"
  s << "else { Write-Warning '  " + vm_name + " SSH not yet reachable -- Ansible will retry' }\n"
  s << "Write-Host '=== [Phase 2] Complete ===' -ForegroundColor Cyan\n"
  s
end

# =============================================================================
Vagrant.configure("2") do |config|

  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "hyperv" do |h|
    h.enable_virtualization_extensions = true
    h.linked_clone                     = true
    h.vm_integration_services          = { guest_service_interface: true }
  end

  MACHINES.each do |vm_cfg|
    config.vm.define vm_cfg[:name] do |m|

      m.vm.box      = vm_cfg[:box]
      m.vm.hostname = vm_cfg[:name].downcase
      m.vm.synced_folder ".", "/vagrant", disabled: true

      # NIC2: GRC-Lab-Switch. NIC1 (Default Switch) is implicit/automatic.
      m.vm.network "private_network", bridge: LAB_SWITCH

      m.vm.provider "hyperv" do |h|
        h.vmname    = vm_cfg[:name]
        h.memory    = vm_cfg[:ram]
        h.maxmemory = vm_cfg[:ram]
        h.cpus      = vm_cfg[:cpus]
      end

      # ── Windows VMs ──────────────────────────────────────────────────────
      if vm_cfg[:name] != "AUDIT-BOX"

        # Vagrant connects via NIC1 (Default Switch DHCP) for initial contact
        m.vm.communicator       = "winrm"
        m.winrm.username        = "vagrant"
        m.winrm.password        = "vagrant"
        m.winrm.transport       = :negotiate
        m.winrm.basic_auth_only = false
        m.winrm.timeout         = 300
        m.winrm.retry_limit     = 20

        # Phase 1: set static IP on NIC2, open WinRM (runs inside VM via NIC1)
        m.vm.provision "shell",
          name:                            "Phase 1 - Set Static Lab IP",
          inline:                          win_phase1(vm_cfg[:ip], PREFIX_LEN),
          powershell_elevated_interactive: false

        # Upload AD population script to DC-PRIMARY while NIC1 is still live
        if vm_cfg[:name] == "DC-PRIMARY"
          script_path = File.join(File.dirname(__FILE__), "scripts/setup/Invoke-ADLabPopulate.ps1")
          if File.exist?(script_path)
            ad_script = File.read(script_path)
            m.vm.provision "shell",
              name:                            "Upload AD Population Script",
              inline:                          "$dest='C:\\Windows\\Temp\\Invoke-ADLabPopulate.ps1'\nSet-Content -Path $dest -Encoding UTF8 -Value @'\n" + ad_script + "\n'@\nWrite-Host '[upload] Written to ' + $dest\n",
              powershell_elevated_interactive: false
          else
            puts "WARNING: Invoke-ADLabPopulate.ps1 not found - skipping upload"
          end
        end

        # Phase 2: host-side Stop-VM / Remove NIC / Start-VM
        # Vagrant does NOT reconnect after a host shell provisioner so
        # the "guest not ready" error never fires.
        m.vm.provision "shell",
          name:       "Phase 2 - Isolate to Lab Network",
          privileged: false,
          inline:     host_isolate(vm_cfg[:name], vm_cfg[:ip], MGMT_SWITCH)

        # All subsequent Vagrant communication (if any) goes via static lab IP
        m.winrm.host = vm_cfg[:ip]

      end

      # ── AUDIT-BOX (Kali) ─────────────────────────────────────────────────
      if vm_cfg[:name] == "AUDIT-BOX"

        # Vagrant connects via NIC1 (Default Switch DHCP)
        m.vm.communicator = "ssh"

        # Phase 1: set static IP on NIC2 (runs inside AUDIT-BOX)
        m.vm.provision "shell",
          name:       "Phase 1 - Set Static Lab IP",
          inline:     linux_phase1(vm_cfg[:ip], PREFIX_LEN),
          privileged: true

        # Phase 2: host-side Stop / Remove NIC / Start
        # After this provisioner Vagrant does NOT try to reconnect,
        # so no "guest not ready" error. The VM comes back on lab IP only.
        m.vm.provision "shell",
          name:       "Phase 2 - Isolate to Lab Network",
          privileged: false,
          inline:     host_isolate_linux(vm_cfg[:name], vm_cfg[:ip], MGMT_SWITCH)

        # All subsequent provisioners connect via the static lab SSH IP
        m.ssh.host = vm_cfg[:ip]

        # Phase 3: install Ansible (VM is now on lab network only)
        m.vm.provision "shell",
          name:       "Phase 3 - Install Ansible",
          path:       "scripts/setup/bootstrap-audit-box.sh",
          privileged: true

        # Phase 4: Ansible runs from AUDIT-BOX over static lab IPs
        m.vm.provision "ansible_local",
          playbook:          "ansible/playbooks/site.yml",
          inventory_path:    "ansible/inventory.yml",
          install:           false,
          limit:             "all",
          verbose:           "v",
          galaxy_role_file:  "ansible/requirements.yml",
          galaxy_roles_path: "/home/vagrant/.ansible/roles",
          extra_vars:        {
            domain_name:             DOMAIN,
            domain_netbios:          NETBIOS,
            dc_primary_ip:           "10.10.10.10",
            dc_secondary_ip:         "10.10.10.11",
            seed_misconfigurations:  true,
            ansible_winrm_transport: "ntlm"
          }

      end

    end
  end

end
