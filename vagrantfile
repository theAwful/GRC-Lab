# -*- mode: ruby -*-
# =============================================================================
# GRC Hyper-V Lab – Vagrantfile
#
# NETWORKING APPROACH
# ───────────────────
# You set static IPs manually on each VM's GRC-Lab-Switch adapter.
# Vagrant connects via the Default Switch (DHCP, auto-detected) to run
# the WinRM bootstrap provisioner. After that it reconnects using
# winrm.host pointed at the static lab IP for all subsequent work.
#
# Boot sequence per VM:
#   1. VM boots -- Default Switch gives it a DHCP address automatically
#   2. Vagrant auto-detects that DHCP address and connects via WinRM
#   3. "Enable WinRM" provisioner runs -- opens WinRM on all adapters
#      including the static lab IP you already set on NIC2
#   4. winrm.host is set to the static IP so all further Vagrant
#      communication goes via the lab network
#
# You do NOT need to manually run anything on each VM.
# You DO need to have set the static IP on each VM's GRC-Lab-Switch
# adapter before running vagrant provision.
#
# Prerequisites:
#   - GRC-Lab-Switch created: .\scripts\setup\create-hyperv-switch.ps1
#   - Static IPs set on each VM's lab NIC (you've already done this)
#   - Vagrant >= 2.4, vagrant-reload plugin, Git
# =============================================================================

DOMAIN  = "corp.grclab.local"
NETBIOS = "GRCLAB"

MACHINES = [
  { name: "DC-PRIMARY",           ip: "10.10.10.10", box: "gusztavvargadr/windows-server-2022-standard", ram: 4096, cpus: 2, linux: false },
  { name: "DC-SECONDARY",         ip: "10.10.10.11", box: "gusztavvargadr/windows-server-2022-standard", ram: 4096, cpus: 2, linux: false },
  { name: "MEMBER-SERVER-01",     ip: "10.10.10.20", box: "gusztavvargadr/windows-server-2019-standard", ram: 4096, cpus: 2, linux: false },
  { name: "MEMBER-SERVER-02",     ip: "10.10.10.21", box: "gusztavvargadr/windows-server-2019-standard", ram: 4096, cpus: 2, linux: false },
  { name: "WORKSTATION-WIN10-01", ip: "10.10.10.31", box: "gusztavvargadr/windows-10-22h2-enterprise",        ram: 4096, cpus: 2, linux: false },
  { name: "WORKSTATION-WIN10-02", ip: "10.10.10.32", box: "gusztavvargadr/windows-10-22h2-enterprise",        ram: 4096, cpus: 2, linux: false },
  { name: "WORKSTATION-WIN11",    ip: "10.10.10.33", box: "gusztavvargadr/windows-11-22h2-enterprise",        ram: 4096, cpus: 2, linux: false },
  { name: "AUDIT-BOX",            ip: "10.10.10.50", box: "kalilinux/rolling",                           ram: 4096, cpus: 2, linux: true  },
].freeze

# WinRM bootstrap -- runs inside the VM via the Default Switch DHCP address.
# Enables WinRM on all adapters (including the static lab IP on NIC2).
# No IP changes, no NIC removal -- just opens the door for Ansible.
WINRM_BOOTSTRAP = <<~'PS'
  Write-Host "[bootstrap] Enabling WinRM..." -ForegroundColor Cyan
  Set-ExecutionPolicy Unrestricted -Scope LocalMachine -Force

  winrm quickconfig -q 2>&1 | Out-Null
  winrm set winrm/config              '@{MaxTimeoutms="300000"}'      2>&1 | Out-Null
  winrm set winrm/config/service      '@{AllowUnencrypted="true"}'    2>&1 | Out-Null
  winrm set winrm/config/service/auth '@{Basic="true"}'               2>&1 | Out-Null
  winrm set winrm/config/service/auth '@{Negotiate="true"}'           2>&1 | Out-Null
  winrm set winrm/config/winrs        '@{MaxMemoryPerShellMB="1024"}' 2>&1 | Out-Null

  Get-NetFirewallRule -Name "WinRM-HTTP-GRC" -ErrorAction SilentlyContinue | Remove-NetFirewallRule
  New-NetFirewallRule -Name "WinRM-HTTP-GRC" -DisplayName "WinRM HTTP (GRC Lab)" `
    -Protocol TCP -LocalPort 5985 -Action Allow -Direction Inbound -Profile Any | Out-Null

  Enable-NetFirewallRule -DisplayName "File and Printer Sharing (Echo Request - ICMPv4-In)" -ErrorAction SilentlyContinue
  Set-ItemProperty -Path "HKLM:\System\CurrentControlSet\Control\Terminal Server" -Name fDenyTSConnections -Value 0
  Enable-NetFirewallRule -DisplayGroup "Remote Desktop" -ErrorAction SilentlyContinue

  Write-Host "[bootstrap] WinRM open on all adapters." -ForegroundColor Green
PS

Vagrant.configure("2") do |config|

  config.vm.synced_folder ".", "/vagrant", disabled: true

  config.vm.provider "hyperv" do |h|
    h.enable_virtualization_extensions = true
    h.linked_clone                     = true
    h.vm_integration_services          = { guest_service_interface: true }
  end

  MACHINES.each do |vm_cfg|
    config.vm.define vm_cfg[:name] do |m|

      m.vm.box      = vm_cfg[:box]
      m.vm.hostname = vm_cfg[:name].downcase
      m.vm.synced_folder ".", "/vagrant", disabled: true
      m.vm.boot_timeout = 600

      m.vm.provider "hyperv" do |h|
        h.vmname    = vm_cfg[:name]
        h.memory    = vm_cfg[:ram]
        h.maxmemory = vm_cfg[:ram]
        h.cpus      = vm_cfg[:cpus]
      end

      # ── Windows VMs ──────────────────────────────────────────────────────
      unless vm_cfg[:linux]

        m.vm.communicator       = "winrm"
        m.winrm.username        = "vagrant"
        m.winrm.password        = "vagrant"
        m.winrm.transport       = :negotiate
        m.winrm.basic_auth_only = false
        m.winrm.timeout         = 300
        m.winrm.retry_limit     = 20
        # winrm.host intentionally NOT set here -- Vagrant auto-detects
        # the Default Switch DHCP address for the initial connection
        # and runs the bootstrap over that. After the bootstrap, WinRM
        # is open on the static lab IP too, so Ansible can reach it.

        # Step 1: open WinRM via Default Switch DHCP connection
        m.vm.provision "shell",
          name:                            "Enable WinRM",
          inline:                          WINRM_BOOTSTRAP,
          powershell_elevated_interactive: false

        # Step 2: upload AD population script to DC-PRIMARY
        if vm_cfg[:name] == "DC-PRIMARY"
          script_path = File.join(File.dirname(__FILE__), "scripts/setup/Invoke-ADLabPopulate.ps1")
          if File.exist?(script_path)
            ad_script = File.read(script_path)
            m.vm.provision "shell",
              name:                            "Upload AD Population Script",
              inline:                          "$dest='C:\\Windows\\Temp\\Invoke-ADLabPopulate.ps1'\nSet-Content -Path $dest -Encoding UTF8 -Value @'\n" + ad_script + "\n'@\nWrite-Host '[upload] Written to ' + $dest\n",
              powershell_elevated_interactive: false
          else
            puts "WARNING: scripts/setup/Invoke-ADLabPopulate.ps1 not found - skipping"
          end
        end

      end

      # ── AUDIT-BOX (Kali) ─────────────────────────────────────────────────
      if vm_cfg[:linux]

        m.vm.communicator = "ssh"
        m.ssh.username    = "vagrant"
        m.ssh.insert_key  = true
        # ssh.host not set -- Vagrant auto-detects Default Switch DHCP address
        # for bootstrap. Ansible then connects to all VMs via static lab IPs
        # (defined in ansible/inventory.yml) independently of Vagrant.

        # Step 1: install Ansible inside AUDIT-BOX
        m.vm.provision "shell",
          name:       "Install Ansible",
          path:       "scripts/setup/bootstrap-audit-box.sh",
          privileged: true

        # Step 2: run Ansible from AUDIT-BOX against all lab VMs
        # Ansible uses the static 10.10.10.x IPs from inventory.yml --
        # it does not go through Vagrant's connection at all.
        m.vm.provision "ansible_local",
          playbook:          "ansible/playbooks/site.yml",
          inventory_path:    "ansible/inventory.yml",
          install:           false,
          limit:             "all",
          verbose:           "v",
          galaxy_role_file:  "ansible/requirements.yml",
          galaxy_roles_path: "/home/vagrant/.ansible/roles",
          extra_vars:        {
            domain_name:             DOMAIN,
            domain_netbios:          NETBIOS,
            dc_primary_ip:           "10.10.10.10",
            dc_secondary_ip:         "10.10.10.11",
            seed_misconfigurations:  true,
            ansible_winrm_transport: "ntlm"
          }

      end

    end
  end

end
